# MUD-AI Environment Variables
# Copy to .env and fill in your values

# Supabase (use Service Role Key for backend writes)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# OpenAI (for embeddings)
OPENAI_API_KEY=sk-...

# Optional: MUD connection details (we'll expand this later)
MUD_HOST=discworld.starturtle.net
MUD_PORT=4242
MUD_CHARACTER=your_character_name
