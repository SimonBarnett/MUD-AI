# MUD-AI Environment Variables
# Copy to .env and fill in your values

# MUD Connection (Discworld example)
MUD_HOST=discworld.starturtle.net
MUD_PORT=4242
MUD_CHARACTER=YourCharacterName
MUD_PASSWORD=your_password_here

# Supabase (for persistent memory + pgvector)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# OpenAI (or xAI/Grok if supported)
OPENAI_API_KEY=sk-your_openai_key_here

# Optional
DEBUG=true