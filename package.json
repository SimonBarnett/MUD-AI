{
  "name": "mud-ai",
  "version": "0.1.1",
  "description": "MUD-AI - Real end-to-end Discworld MUD agent with Grok 4.3 + Supabase",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "dev": "cross-env OPENAI_LOG=none FORCE_COLOR=1 tsx --no-cache src/index.ts",
