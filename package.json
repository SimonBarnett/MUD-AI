    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/node": "^20.16.0",
    "@types/ws": "^8.5.13",
    "cross-env": "^7.0.3",
    "eslint": "^9.12.0",
    "typescript": "^5.6.3"
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "mud",
